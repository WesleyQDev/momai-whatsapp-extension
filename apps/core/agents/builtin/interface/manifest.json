{
  "id": "com.momai.builtin.interface",
  "name": "SystemAgent",
  "author": "MomAI Core",
  "version": "1.1.0",
  "description": "System control, window management, and application settings.",
  "icon": "Settings",
  "entry": "plugin.py",
  "system_prompt": "You are the SystemAgent of MomAI. Your function is to control system-level settings and the application window. You handle tasks like changing themes, reloading the app, managing the sidebar, or closing the interface. You do NOT need to be called just to show content; other agents can do that. Focus on *control* and *configuration*.",
  "intents": [
    "Change application theme",
    "Reload the application",
    "Open sidebar tabs",
    "Open settings panel",
    "Close the side panel",
    "Open the extension store settings",
    "System status and resources",
    "Change TTS voice",
    "Enable or disable TTS",
    "Enable or disable wake word",
    "Add FortScript monitored app",
    "Stop response generation",
    "Stop voice playback"
  ],
  "features": {
    "sidebar": false,
    "agent_name": "system",
    "tools": [
      "show_interface",
      "close_interface",
      "get_momai_resources_tool",
      "set_theme",
      "open_settings_panel",
      "open_sidebar_tab",
      "set_tts_enabled",
      "set_wake_word_enabled",
      "set_tts_voice",
      "get_tts_voice_catalog",
      "add_fortscript_app",
      "open_extension_store",
      "stop_generation",
      "stop_voice"
    ],
    "safe_tools": [
      "set_theme",
      "open_settings_panel",
      "open_sidebar_tab",
      "open_extension_store",
      "get_tts_voice_catalog",
      "stop_generation",
      "stop_voice"
    ]
  }
}