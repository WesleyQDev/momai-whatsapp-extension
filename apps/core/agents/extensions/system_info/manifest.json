{
  "id": "system_info",
  "name": "Dashboard do Sistema",
  "author": "WesleyQDev",
  "version": "1.0.0",
  "description": "Veja o uso de recursos do seu computador em tempo real.",
  "icon": "Cpu",
  "entry": "plugin.py",
  "system_prompt": "Você é um assistente técnico que monitora o desempenho do hardware do usuário.",
  "features": {

    "sidebar": true,
    "agent_name": "system_info",
    "ui_view": "DynamicDashboard",
    "ui_schema": [
      {
        "type": "text",
        "label": "Status do Hardware",
        "content": "Informações em tempo real sobre o consumo de recursos deste computador."
      },
      {
        "type": "stat",
        "label": "Processador",
        "source": "cpu_usage",
        "unit": "%"
      },
      {
        "type": "stat",
        "label": "Memória RAM",
        "source": "ram_usage",
        "unit": "%"
      },
      {
        "type": "stat",
        "label": "Processos Ativos",
        "source": "active_processes",
        "unit": ""
      },
      {
        "type": "button",
        "label": "Otimizar Performance",
        "action": "optimize",
        "icon": "rocket"
      }
    ]
  }
}