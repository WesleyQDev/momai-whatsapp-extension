{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "MomAI",
  "colors": {
    "primary": "#8B5CF6",
    "light": "#A78BFA",
    "dark": "#7C3AED"
  },
  "appearance": {
    "default": "dark"
  },
  "background": {
    "decoration": "gradient"
  },
  "favicon": "/logo/logo.png",
  "logo": {
    "light": "/logo/logo.png",
    "dark": "/logo/logo.png",
    "href": "https://github.com/WesleyQDev/MomAI"
  },

  "footer": {
    "socials": {
      "github": "https://github.com/WesleyQDev/MomAI"
    }
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": "system",
    "anchors": "sections"
  },
  "contextual": {
    "options": ["copy", "chatgpt", "claude", "cursor"]
  },
  "navigation": {
    "languages": [
      {
        "language": "pt-BR",
        "tabs": [
          {
            "tab": "Documentação",
            "groups": [
              {
                "group": "Começando",
                "icon": "rocket",
                "pages": [
                  "pt-BR/introducao",
                  "pt-BR/por-que-momai",
                  "pt-BR/instalacao",
                  "pt-BR/inicio-rapido"
                ]
              },
              {
                "group": "Arquitetura",
                "icon": "diagram-project",
                "pages": [
                  "pt-BR/arquitetura/visao-geral",
                  "pt-BR/arquitetura/backend",
                  "pt-BR/arquitetura/frontend"
                ]
              },
              {
                "group": "Extensões",
                "icon": "puzzle-piece",
                "pages": [
                  "pt-BR/extensoes/conceitos",
                  "pt-BR/extensoes/criando-extensao"
                ]
              },
              {
                "group": "Comunidade",
                "icon": "users",
                "pages": [
                  "pt-BR/contribuindo",
                  "pt-BR/updates"
                ]
              }
            ]
          },
          {
            "tab": "Fortscript",
            "groups": [
              {
                "group": "Começando",
                "pages": [
                  "pt-BR/fortscript/index",
                  "pt-BR/fortscript/quick-start",
                  "pt-BR/fortscript/cli"
                ]
              },
              {
                "group": "Referência",
                "pages": [
                  "pt-BR/fortscript/yaml-config",
                  "pt-BR/fortscript/argumentos",
                  "pt-BR/fortscript/games"
                ]
              },
              {
                "group": "Exemplos",
                "pages": ["pt-BR/fortscript/exemplo-real"]
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/WesleyQDev/MomAI",
          "icon": "github"
        },
        {
          "anchor": "Download",
          "href": "https://wesleyqdev.github.io/momai/",
          "icon": "download"
        }
      ]
    }
  }
}
