{
  "name": "momai",
  "version": "1.0.0",
  "description": "MomAI - Assistente de IA para mães",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:dev:desktop\" \"npm:dev:python\"",
    "dev:python": "cd apps/core && uv run uvicorn main:app --reload --host 127.0.0.1 --port 8000",
    "dev:desktop": "turbo run dev --filter=desktop",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "turbo run format",
    "docs": "cd apps/docs && mint dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.27.0",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "turbo": "^2.7.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "electron-winstaller"
    ]
  }
}
