{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "MomAI",
  "colors": {
    "primary": "#6366f1",
    "light": "#818cf8",
    "dark": "#4f46e5"
  },
  "favicon": "./icon.png",
  "navigation": {
    "languages": [
      {
        "language": "pt-BR",
        "tabs": [
          {
            "tab": "MomAI",
            "groups": [
              {
                "group": "MomAI",
                "pages": ["pt-BR/index", "pt-BR/por-que-momai","pt-BR/evolucao"]
              },
              {
                "group": "Comunidade",
                "pages": [
                  "pt-BR/como-colaborar",
                  "pt-BR/frontend",
                  "pt-BR/backend",
                  "pt-br/extensões"
                ]
              }
            ]
          },
          {
            "tab": "Fortscript",
            "groups": [
              {
                "group": "Fortscript",
                "pages": ["pt-BR/fortscript"]
              }
            ]
          }
        ]
      }
    ],

    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/WesleyQDev/MomAI",
          "icon": "github"
        },
        {
          "anchor": "Baixar MomAI",
          "href": "https://wesleyqdev.github.io/momai-docs/",
          "icon": "download"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/logo.png",
    "dark": "/logo/logo.png"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://wesleyqdev.github.io/momai-docs/",
        "icon": "github"
      },
      {
        "label": "Baixar MomAI",
        "href": "https://wesleyqdev.github.io/momai-docs/"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/WesleyQDev/MomAI"
    }
  }
}
